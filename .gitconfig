[user]
	name = Patrick Evans
	email = pat@pve.dev
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIN0Jtdt0hDYEYVTiWjsue0PxcWWhzUQEwjVQBAqsd8rT
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[include]
	path = .gitconfig.work
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[init]
	defaultBranch = main
